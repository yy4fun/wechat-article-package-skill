WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# Optional: reuse an access token you obtained elsewhere.
# WECHAT_ACCESS_TOKEN=existing_access_token

WECHAT_ARTICLE_TITLE=Your article title
WECHAT_ARTICLE_AUTHOR=Your author name
WECHAT_ARTICLE_DIGEST=Short article digest
WECHAT_CONTENT_SOURCE_URL=https://example.com/source

# Defaults are relative to the current working directory where the script runs.
WECHAT_HTML_PATH=wechat-draft.html
WECHAT_COVER_PATH=output/wechat-21x9-cover.png

# Optional: use an existing permanent media id for cover instead of uploading coverPath.
# WECHAT_THUMB_MEDIA_ID=your_permanent_cover_media_id
